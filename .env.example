# Copy this to .env and fill in values

# Flask secret key — set a long random string in production
FLASK_SECRET_KEY=change_me_to_random_string_min_32_chars

# Telegram Bot Token — get from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs with admin access
# Get your ID from @userinfobot
ADMIN_IDS=

# Admin token for Basic Auth fallback (dev/testing only, optional)
# Access admin panel: any username + this password
ADMIN_TOKEN=

# Storage mode: leave empty for JSON (default), set 'sql' for PostgreSQL
# STORAGE=sql
# DATABASE_URL=postgresql://user:password@localhost/nanny_db

# Force HTTPS redirect (set to 1 on production behind proxy)
# FORCE_HTTPS=1

# Canonical site URL — IMPORTANT for sitemap.xml and robots.txt
# Without this, Google may index localhost URLs instead of your real domain!
# Example: SITE_URL=https://nanny-portal.up.railway.app
SITE_URL=

# Secret for /cron/remind_2h endpoint protection
# Set a random string and pass it as ?secret= or X-Cron-Secret header
CRON_SECRET=

# Timezone for shift reminders (default: Asia/Ho_Chi_Minh)
# SHIFT_TZ=Asia/Ho_Chi_Minh

# Port (default 5000)
# PORT=5000
